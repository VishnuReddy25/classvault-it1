rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Students collection ──────────────────────────────
    match /students/{studentId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Claims (PIN ownership) ───────────────────────────
    match /claims/{claimId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Wall posts ───────────────────────────────────────
    match /wallPosts/{postId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Testimonials ─────────────────────────────────────
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Media vault ──────────────────────────────────────
    match /media/{mediaId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Vaults ───────────────────────────────────────────
    match /vaults/{vaultId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Catch-all fallback ───────────────────────────────
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
